---
import ImageCard from "./ImageCard.astro";
const offers = [
    {
        imageURL:"/OfferBurger.jpeg",
        offerText:""
    },
    {
        imageURL:"/OfferCheeseBurger.jpeg",
        offerText:""
    },
    {
        imageURL:"/OfferEmpanadas.jpeg",
        offerText:""
    },
    {
        imageURL:"/OfferPizza.jpeg",
        offerText:""
    },
    {
        imageURL:"/OfferPizza2.jpeg",
        offerText:""
    },
    {
        imageURL:"/OfferPizza3.jpeg",
        offerText:""
    }
  
